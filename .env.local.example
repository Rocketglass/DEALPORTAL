# ===========================================
# Rocket Realty Portal — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ------ Supabase ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ DocuSign ------
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_SECRET_KEY=your-secret-key
DOCUSIGN_ACCOUNT_ID=your-account-id
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_CONNECT_HMAC_SECRET=your-hmac-secret
DOCUSIGN_RSA_PRIVATE_KEY=your-rsa-private-key
DOCUSIGN_USER_ID=your-user-id

# ------ Resend (Email) ------
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=notifications@rocketrealty.com
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# ------ Upstash Redis (Rate limiting) ------
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ------ Gemini (optional — enables AI refinement on LOI drafting) ------
# Leave unset to fall back to the rule-based draft generator.
GEMINI_API_KEY=

# ------ Sentry (Error Monitoring) ------
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=rocket-realty-portal

# ------ App ------
# Used in all email links and portal URLs. Set to production domain in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000
